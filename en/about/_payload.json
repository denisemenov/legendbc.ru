ый экран","/images/tv_3.jpg",[63,231],{},[66,233,235],{"id":234},"vip-залы","VIP-залы",[13,237,238],{},"Каждый VIP-зал оборудован столами для русского бильярда.",[63,240],{},[66,242,244],{"id":243},"кухня-и-бар","Кухня и бар",[13,246,247,248,253],{},"С меню бара и кухни вы можете ознакомиться в разделе ",[249,250,252],"a",{"href":251},"price.html","Цены",".",{"title":19,"searchDepth":255,"depth":255,"links":256},2,[257,259,260,261,262,263],{"id":68,"depth":258,"text":69},3,{"id":114,"depth":258,"text":115},{"id":171,"depth":258,"text":172},{"id":193,"depth":258,"text":194},{"id":234,"depth":258,"text":235},{"id":243,"depth":258,"text":244},"Описание бильярдного клуба Легенда","md",{},true,"/about",{"title":5,"description":264},"about",1738156524151]